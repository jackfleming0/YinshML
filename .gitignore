# Ignore everything first
*

# Then un-ignore specific directories and files we want
!scripts/
!scripts/**
!yinsh_ml/
!yinsh_ml/**
!configs/
!configs/*.yaml
!configs/panel_calibration.json
# Heuristic weight artifacts (WeightManager JSON). Version-controlled so the
# baseline + any promoted re-fit weights are reproducible references. Generated
# per-experiment arm configs under configs/experiments/ stay ignored.
!configs/heuristic_weights/
!configs/heuristic_weights/**
configs/local/
!experiments/
!experiments/**
# Exclude ALL training-artifact binaries inside experiments/ — checkpoints,
# replay buffers, optimizer state, exported models. GitHub rejects >100MB
# files; these are recoverable from logs/metrics and shouldn't be in the
# repo. Configs (yaml), metrics (json), and tournament logs stay tracked.
experiments/**/*.pt
experiments/**/*.pkl
experiments/**/*.pkl.gz
experiments/**/*.mlpackage
experiments/**/*.mlmodel
experiments/**/*.npy
experiments/**/*.npz
!pyproject.toml
!requirements.txt
!setup.py
# Interactive HTML guided tour of the codebase (self-contained learning guide)
!codebase-guide/
!codebase-guide/**
# Internal architecture atlas (systems/contracts reference)
!architecture-atlas/
!architecture-atlas/**
# Analysis board (position composer + alignment loop scripts). Source is
# allowlisted; generated run outputs (positions, measurements, reports,
# charts) live under loop/runs/<timestamp>/ and stay ignored.
!analysis_board/
!analysis_board/**
analysis_board/loop/runs/
# yngine eval harness — vendored C++ driver source + the temhelk/yngine submodule
# pointer (the submodule directory itself is populated on `git submodule update`
# and never directly committed beyond the gitlink, so allowlisting the parent is
# enough).
!third_party/
!third_party/yngine_driver/
!third_party/yngine_driver/**
!third_party/yngine
third_party/yngine/**
# Build artifacts from `bash third_party/yngine_driver/build.sh` — never
# committed; the build script is idempotent and rebuilds in minutes.
third_party/yngine_driver/build-release/
third_party/yngine_driver/build*/
!.gitmodules
# Opening-theory diagnostic outputs: self-play + heuristic-baseline parquet
# dumps. Reproducible by re-running scripts/measure_model_openings.py and
# the heuristic-baseline generator; would otherwise accumulate.
analysis_board/multiplayer/data_runs/
# Per-day JSONL game logs from /api/move — private (friend play patterns),
# accumulating, never push to the public repo.
analysis_board/multiplayer/deploy/games/
# Server-side cache for the Review-mode BGA imports. LRU, capped at 1000
# entries, rebuilt on demand from BGA — never source of truth, never
# checked in.
analysis_board/multiplayer/bga_imports/

