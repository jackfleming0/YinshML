<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jackfleming.yinsh-server</string>

    <key>WorkingDirectory</key>
    <string>/Users/jackfleming/PycharmProjects/YinshML</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jackfleming/PycharmProjects/YinshML/venv/bin/python</string>
        <string>/Users/jackfleming/PycharmProjects/YinshML/analysis_board/server.py</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- Bind to localhost only — cloudflared talks to us over loopback. -->
        <key>YNS_HOST</key>
        <string>127.0.0.1</string>
        <key>YNS_PORT</key>
        <string>5173</string>
        <!-- Public-access sim cap. 3200 ≈ 22s worst-case eval on Apple Silicon.
             Bumped from 1600 after a strong-player tester reported no perceptible
             difference between Standard/Strong — wanted to expose the full
             "Deep" option to test whether the dial is real or placebo. -->
        <key>YNS_MAX_NUM_SIMS</key>
        <string>3200</string>
        <!-- Owner bypass for the cap above. An eval request carrying this
             token (Advanced MCTS → "Owner token" in the board, persisted to
             your browser's localStorage) skips YNS_MAX_NUM_SIMS, so you can
             run 256000-sim searches while public visitors stay capped. This
             is a deliberately simple shared secret, not a strong credential —
             it only needs to stop friends from *accidentally* queuing a giant
             run, not a determined attacker. Swap in `openssl rand -hex 24` if
             you ever need real protection. Empty = bypass disabled. -->
        <key>YNS_OWNER_TOKEN</key>
        <string>jackfleming</string>
        <!-- MPS = Apple Silicon GPU. Fall back to "cpu" if MPS misbehaves. -->
        <key>YNS_DEVICE</key>
        <string>mps</string>
    </dict>

    <!-- Restart automatically on crash / exit. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Logs land alongside this plist in deploy/. Truncate manually if they
         grow too large; no rotation built in. -->
    <key>StandardOutPath</key>
    <string>/Users/jackfleming/PycharmProjects/YinshML/analysis_board/multiplayer/deploy/yinsh-server.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jackfleming/PycharmProjects/YinshML/analysis_board/multiplayer/deploy/yinsh-server.err.log</string>
</dict>
</plist>
